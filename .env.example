# Copie para .env e ajuste. O .env nao vai pro git (ver .gitignore).

# --- Proxy / dominio ---------------------------------------------------------
# Local: localhost  |  Producao: eyes.seudominio.com
SITE_ADDRESS=localhost
# Email usado pelo Let's Encrypt (so necessario em producao com dominio real).
ACME_EMAIL=

# --- App web -----------------------------------------------------------------
# URL publica da aplicacao (usada em links/callbacks).
APP_URL=http://localhost:3000
# Segredo de sessao do login single-tenant (gere com: openssl rand -hex 32).
AUTH_SECRET=
# Senha unica de acesso ao MVP (login interno).
APP_PASSWORD=troque-esta-senha

# --- Banco de dados (Postgres no compose) ------------------------------------
POSTGRES_USER=codara
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=codara_eyes

# --- IA (DeepSeek) -----------------------------------------------------------
# Sem a chave, o worker gera um relatorio fallback baseado nos scores.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
